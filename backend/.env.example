# Django
SECRET_KEY=dev-secret-key-change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=englishnow
DB_USER=root
DB_PASSWORD=1234
